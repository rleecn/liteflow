{
  "name": "@rleecn/liteflow",
  "version": "0.1.0",
  "description": "高性能节点式工作流 Vue 组件，基于 Canvas 2D 渲染，支持万级节点",
  "main": "./dist/liteflow.umd.js",
  "module": "./dist/liteflow.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/liteflow.mjs",
      "require": "./dist/liteflow.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "screenshot.jpeg",
    "LICENSE"
  ],
  "keywords": [
    "vue",
    "node-editor",
    "graph",
    "canvas",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.37",
    "vue-tsc": "^3.3.4"
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch"
  }
}
